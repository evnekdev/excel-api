{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "source.schema.json",
  "title": "Excel source coverage record and shared definitions",
  "type": "object",
  "required": ["schema_version", "source", "selected_files", "parsed_files", "skipped_files", "warnings", "orphan_records", "duplicate_ids", "unresolved_owner_references", "unresolved_return_object_references", "missing_summaries", "missing_source_paths", "unresolved"],
  "properties": {
    "schema_version": { "const": 1 },
    "source": { "$ref": "#/$defs/manifest_source" },
    "selected_files": { "type": "integer", "minimum": 0 },
    "parsed_files": { "type": "integer", "minimum": 0 },
    "skipped_files": { "type": "array", "items": { "$ref": "#/$defs/issue" } },
    "warnings": { "type": "array", "items": { "$ref": "#/$defs/issue" } },
    "orphan_records": { "type": "array", "items": { "$ref": "#/$defs/issue" } },
    "duplicate_ids": { "type": "array", "items": { "$ref": "#/$defs/issue" } },
    "unresolved_owner_references": { "type": "array", "items": { "$ref": "#/$defs/issue" } },
    "unresolved_return_object_references": { "type": "array", "items": { "$ref": "#/$defs/issue" } },
    "missing_summaries": { "type": "array", "items": { "$ref": "#/$defs/issue" } },
    "missing_source_paths": { "type": "array", "items": { "$ref": "#/$defs/issue" } },
    "unresolved": { "type": "array", "items": { "$ref": "#/$defs/issue" } }
  },
  "$defs": {
    "source_ref": { "type": "object", "required": ["repository", "commit", "path", "extraction_method"], "properties": { "repository": { "type": "string", "format": "uri" }, "commit": { "type": "string", "pattern": "^[0-9a-fA-F]{40}$" }, "path": { "type": "string", "pattern": "^(?!/)(?!.*\\\\).+" }, "extraction_method": { "type": "string", "minLength": 1 } }, "additionalProperties": false },
    "manifest_source": { "type": "object", "required": ["name", "repository", "commit", "retrieved", "documentation_license", "sample_code_license"], "properties": { "name": { "type": "string" }, "repository": { "type": "string", "format": "uri" }, "commit": { "type": "string", "pattern": "^[0-9a-fA-F]{40}$" }, "retrieved": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" }, "documentation_license": { "type": "string" }, "sample_code_license": { "type": "string" } }, "additionalProperties": false },
    "documentation": { "type": "object", "required": ["title", "api_names"], "properties": { "title": { "type": "string" }, "api_names": { "type": "array", "items": { "type": "string" } } }, "additionalProperties": false },
    "verification": { "type": "object", "required": ["documentation", "typelib", "runtime"], "properties": { "documentation": { "type": "boolean" }, "typelib": { "type": "boolean" }, "runtime": { "type": "boolean" } }, "additionalProperties": false },
    "implementation": { "type": "object", "required": ["status"], "properties": { "status": { "enum": ["unplanned", "planned", "implemented", "tested", "stable", "deferred", "unsupported"] } }, "additionalProperties": false },
    "examples": { "type": "object", "required": ["count", "anchors", "copied"], "properties": { "count": { "type": "integer", "minimum": 0 }, "anchors": { "type": "array", "items": { "type": "string" } }, "copied": { "const": false } }, "additionalProperties": false },
    "provenance": { "type": "object", "additionalProperties": { "type": "string", "minLength": 1 } },
    "issue": { "type": "object", "required": ["category", "id", "path", "detail"], "properties": { "category": { "type": "string" }, "id": { "type": ["string", "null"] }, "path": { "type": "string" }, "detail": { "type": "string" } }, "additionalProperties": false }
  },
  "additionalProperties": false
}

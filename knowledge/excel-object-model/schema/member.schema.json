{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "member.schema.json",
  "title": "Excel member record",
  "type": "object",
  "required": ["schema_version", "id", "kind", "owner", "name", "summary", "access", "parameters", "documented_return_type", "source", "documentation", "dispatch", "verification", "implementation", "examples", "provenance"],
  "properties": {
    "schema_version": { "const": 1 },
    "id": { "type": "string", "pattern": "^Excel\\." },
    "kind": { "enum": ["property", "method", "event", "unresolved"] },
    "owner": { "type": "string", "pattern": "^Excel\\." },
    "name": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1, "maxLength": 240 },
    "access": { "enum": ["read-only", "read-write", "write-only", "unknown", "not-applicable"] },
    "parameters": { "type": "array", "items": { "type": "object", "required": ["name", "optionality", "documented_type", "summary"], "properties": { "name": { "type": "string", "minLength": 1 }, "optionality": { "enum": ["required", "optional", "unknown"] }, "documented_type": { "type": ["string", "null"] }, "summary": { "type": ["string", "null"], "maxLength": 240 } }, "additionalProperties": false } },
    "documented_return_type": { "type": ["string", "null"] },
    "source": { "$ref": "source.schema.json#/$defs/source_ref" },
    "documentation": { "$ref": "source.schema.json#/$defs/documentation" },
    "dispatch": { "type": "object", "required": ["dispid", "invoke_kinds"], "properties": { "dispid": { "type": ["integer", "null"] }, "invoke_kinds": { "type": "array", "items": { "type": "string" } } }, "additionalProperties": false },
    "verification": { "$ref": "source.schema.json#/$defs/verification" },
    "implementation": { "$ref": "source.schema.json#/$defs/implementation" },
    "examples": { "$ref": "source.schema.json#/$defs/examples" },
    "provenance": { "$ref": "source.schema.json#/$defs/provenance" }
  },
  "additionalProperties": false
}
